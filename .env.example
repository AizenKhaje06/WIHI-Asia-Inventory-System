# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!

# ============================================
# SUPABASE (Primary Database) - REQUIRED
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# RESEND (Email Service) - OPTIONAL
# ============================================
# Used for sending password reset emails
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# NOTES
# ============================================
# 1. Get Supabase credentials from: https://app.supabase.com/project/_/settings/api
# 2. Keep SUPABASE_SERVICE_ROLE_KEY secret - it has full database access
# 3. Resend is optional - forgot password will work without it (logs temp password instead)
